{
  "name": "easy-nextjs-navbar",
  "version": "0.2.1",
  "description": "Reusable, localized sticky navbar for Next.js",
  "author": "Alice Orlandini <info@aliceorlandini.it> (https://aliceorlandini.it)",
  "keywords": [
    "navbar",
    "navigation",
    "nextjs",
    "next.js",
    "react",
    "tailwindcss",
    "sticky",
    "localization",
    "i18n",
    "server-component",
    "app-router",
    "mobile",
    "hamburger",
    "language-switcher"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AliceOrlandini/easy-nextjs-navbar"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "easy-nextjs-navbar": "./dist/cli-entry.cjs"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "dependencies": {
    "hamburger-react": "^2.5.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "next": "^14.0.0",
    "playwright": "^1.59.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
